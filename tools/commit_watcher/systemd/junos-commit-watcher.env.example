# Optional environment overrides for the Junos Commit Watcher systemd service.
# Any value set here takes precedence over tools/config.yaml.
# Copy/edit as needed, then reference it from the unit's EnvironmentFile=.
#
# Keep this file readable only by the service user, since it may hold secrets:
#   sudo chown junos-watcher:junos-watcher junos-commit-watcher.env
#   sudo chmod 600 junos-commit-watcher.env

# --- Syslog listener -------------------------------------------------------
#SYSLOG_HOST=0.0.0.0
#SYSLOG_PORT=5514

# --- MongoDB ---------------------------------------------------------------
#MONGODB_URI=mongodb://localhost:27017
#MONGODB_DB=junos_commits
#MONGODB_COLLECTION=commit_diffs

# --- Config file path (if not passed via --config) -------------------------
#WATCHER_CONFIG=/opt/juniper_api/tools/config.yaml
